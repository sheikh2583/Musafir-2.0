# ─── Musafir Backend Environment ────────────────────────────
NODE_ENV=development
PORT=5000

# MongoDB Configuration
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/musafir_db?retryWrites=true&w=majority

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRE=30d

# CORS Configuration (Optional)
# ALLOWED_ORIGINS=http://localhost:3000,http://localhost:19006

# Quran Search Mode (ollama or vector)
QURAN_SEARCH_MODE=vector

# LangChain AI Chat Service URL (services/ai)
LANGCHAIN_API_URL=http://127.0.0.1:5001/chat
