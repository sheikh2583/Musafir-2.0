# ============================================================
# MUSAFIR — Unified Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values.
# Each service reads from its own .env or inherits from root.

# ─── General ────────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ─── MongoDB Atlas ──────────────────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/musafir_db?retryWrites=true&w=majority

# ─── JWT Authentication ────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRE=30d

# ─── CORS (Optional) ───────────────────────────────────────
# ALLOWED_ORIGINS=http://localhost:3000,http://localhost:19006

# ─── Quran Semantic Search (backend/ml-search) ─────────────
# Options: "vector" (ONNX BGE embeddings, offline) or "ollama" (LLM-based, requires Ollama)
QURAN_SEARCH_MODE=vector

# ─── Ollama LLM (if QURAN_SEARCH_MODE=ollama) ──────────────
OLLAMA_API_URL=http://127.0.0.1:11434/api/chat
OLLAMA_MODEL=qwen3:8b

# ─── LangChain AI Chat Service (services/ai) ───────────────
LANGCHAIN_PORT=5001
LANGCHAIN_LLM_MODEL=llama3.2
LANGCHAIN_EMBEDDING_MODEL=nomic-embed-text
LANGCHAIN_CHROMA_DB_PATH=./services/ai/chroma_db

# ─── ML Scoring Service (services/ml-scoring) ──────────────
ML_SCORING_PORT=8000
# Arabic-CLIP model for handwriting evaluation

# ─── Gemini API (mobile-app AIScoringService fallback) ─────
GEMINI_API_KEY=your_gemini_api_key_here

# ─── Mobile App API Base URL ───────────────────────────────
# Update to match your machine's IP for Expo dev
API_BASE_URL=http://192.168.1.100:5000/api

# ─── Aladhan API (Islamic Calendar) ────────────────────────
# Public API, no key needed. Override base URL if using proxy:
# ALADHAN_API_URL=https://api.aladhan.com/v1
